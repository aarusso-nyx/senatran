{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "incremental": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["apps/**/*.ts", "domain/**/api/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "tools/**", "tests/**"]
}
