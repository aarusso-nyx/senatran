{
  "extends": "./tsconfig.json",
  "comment": "Emit ESM (inherits module=ESNext). package.json is type:module and sources use explicit .js specifiers, so dist runs directly under `node`.",
  "compilerOptions": {
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "noEmit": false,
    "incremental": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["apps/**/*.ts", "domain/**/api/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "tools/**", "tests/**"]
}
