{
  "name": "senatran-mock",
  "version": "0.0.1",
  "description": "SENATRAN / WSDenatran public API — dev-only mock services provider (NestJS + Postgres). DEVAI runtime host.",
  "author": "Antonio Augusto Russo",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "openapi:check": "tsx tools/scripts/verify-openapi.ts",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "tsx watch --tsconfig tsconfig.json apps/api/src/main.ts",
    "start:debug": "tsx watch --inspect --tsconfig tsconfig.json apps/api/src/main.ts",
    "db:apply": "bash database/apply.sh",
    "db:reset": "bash database/apply.sh --full --sample",
    "db:seed": "bash database/seed.sh",
    "seed:generate": "tsx tools/scripts/generate-seed.ts",
    "devai": "node ../devai/packages/cli/dist/bin.js",
    "devai:doctor": "node ../devai/packages/cli/dist/bin.js doctor --adopter --repo-root .",
    "devai:inventory": "node ../devai/packages/cli/dist/bin.js inv-regen --repo-root .",
    "devai:scorecard": "node ../devai/packages/cli/dist/bin.js score-compute --readings-dir .devai/state/sensor-readings --latest-per-kind --view grid --no-color --human",
    "check": "pnpm lint && pnpm typecheck && pnpm openapi:check && pnpm test:unit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "SENATRAN_TEST_TIER=integration vitest run",
    "test:e2e": "SENATRAN_TEST_TIER=e2e vitest run",
    "test:cov": "vitest run --coverage",
    "test:ci": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "fix": "pnpm format && pnpm lint:fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
