{
  "schemaVersion": "1.0.0",
  "version": "0.1.0",
  "invariants": [
    {
      "id": "INV-AUTH-001",
      "tests": [
        {
          "suite": "e2e",
          "path": "tests/e2e/auth.e2e.spec.ts",
          "names": ["INV-AUTH-001"],
          "assertions": [
            "requests without x-cpf-usuario return 401 with {returnCode,message}",
            "x-client-cert-cn not allowlisted returns 401 when AUTH_CERT_SIMULATION=on",
            "x-cpf-usuario 00000000000 forces 401"
          ]
        }
      ],
      "code_areas": [
        "apps/api/src/common/guards/**",
        "domain/shared/api/src/**"
      ]
    },
    {
      "id": "INV-HTTP-001",
      "tests": [
        {
          "suite": "e2e",
          "path": "tests/e2e/error-envelope.e2e.spec.ts",
          "names": ["INV-HTTP-001"],
          "assertions": [
            "every non-2xx body is exactly {returnCode,message}",
            "returnCode equals the HTTP status for 400/401/402/404/500"
          ]
        }
      ],
      "code_areas": ["apps/api/src/common/filters/**"]
    },
    {
      "id": "INV-API-001",
      "tests": [
        {
          "suite": "int",
          "path": "tests/integration/contract-views.integration.spec.ts",
          "names": ["INV-API-001"],
          "assertions": [
            "each contract.* view returns a payload matching its OpenAPI schema",
            "services issue a single parameterized query per endpoint"
          ]
        }
      ],
      "code_areas": ["domain/**/api/src/**", "database/ddl/**"]
    },
    {
      "id": "INV-DATA-001",
      "tests": [
        {
          "suite": "unit",
          "path": "tests/unit/seed-formats.spec.ts",
          "names": ["INV-DATA-001"],
          "assertions": [
            "generated CPF/CNPJ pass mod-11 check-digit validation",
            "regenerating seeds yields byte-identical SQL"
          ]
        }
      ],
      "code_areas": ["tools/scripts/**", "database/seed/**"]
    },
    {
      "id": "INV-SCEN-001",
      "tests": [
        {
          "suite": "e2e",
          "path": "tests/e2e/scenarios.e2e.spec.ts",
          "names": ["INV-SCEN-001"],
          "assertions": [
            "present id -> 200, absent -> 404, malformed -> 400",
            "magic keys force 402/500 per scenarios.md"
          ]
        }
      ],
      "code_areas": ["apps/api/src/common/**", "database/seed/**"]
    },
    {
      "id": "INV-SEC-001",
      "tests": [
        {
          "suite": "unit",
          "path": "tests/unit/dev-only-config.spec.ts",
          "names": ["INV-SEC-001"],
          "assertions": [
            "default config targets a local database only",
            "no real SENATRAN hostnames or credentials are committed"
          ]
        }
      ],
      "code_areas": ["apps/api/src/**", ".env.example"]
    },
    {
      "id": "INV-RENACH-001",
      "tests": [
        {
          "suite": "e2e",
          "path": "tests/e2e/renach-workflow.e2e.spec.ts",
          "names": ["INV-RENACH-001"],
          "assertions": [
            "process state transitions follow the RENACH state machine",
            "exam type/clinic/examiner rule violations return 402 with the domain code",
            "unknown process returns 404 RENACH.PROCESS.NOT_FOUND"
          ]
        }
      ],
      "code_areas": ["domain/renach/api/src/**", "database/ddl/**"]
    },
    {
      "id": "INV-RENAINF-001",
      "tests": [
        {
          "suite": "e2e",
          "path": "tests/e2e/renainf-workflow.e2e.spec.ts",
          "names": ["INV-RENAINF-001"],
          "assertions": [
            "penalty before defense handling returns 402 PENALTY/CASE.INVALID_STATUS",
            "second-instance before JARI returns 402 APPEAL.PREVIOUS_INSTANCE_REQUIRED",
            "unknown case returns 404 RENAINF.CASE.NOT_FOUND"
          ]
        }
      ],
      "code_areas": ["domain/renainf/api/src/**", "database/ddl/**"]
    },
    {
      "id": "INV-IDEMP-001",
      "tests": [
        {
          "suite": "int",
          "path": "tests/integration/idempotency-audit.integration.spec.ts",
          "names": ["INV-IDEMP-001"],
          "assertions": [
            "replaying a write with the same natural key / Idempotency-Key returns the original result",
            "every state transition writes an audit.evento row with a payload hash"
          ]
        }
      ],
      "code_areas": [
        "domain/renach/api/src/**",
        "domain/renainf/api/src/**",
        "domain/shared/api/src/**"
      ]
    }
  ]
}
