# ---------------------------------------------------------------------------
# SENATRAN mock — environment template. Copy to .env for local dev.
# ---------------------------------------------------------------------------

# Application
NODE_ENV=development
PORT=3000
# Global route prefix. The WSDenatran contract is versioned under /v1, so the
# effective base path is `${API_PREFIX}` and controllers own the `v1/...` part.
API_PREFIX=

# Database (Postgres.app 18 local, trust auth — no password needed)
DATABASE_URL=postgres://postgres@localhost:5432/senatran
DB_HOST=localhost
DB_PORT=5432
DB_NAME=senatran
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_QUERY_TIMEOUT_MS=15000

# Auth simulation (header-based; see docs/framework/contracts/auth.md)
# When 'on', requests must present x-client-cert-cn matching mock.usuario_autorizado.
# The x-cpf-usuario header is ALWAYS required regardless of this flag.
AUTH_CERT_SIMULATION=on
# Comma-separated dev cert CNs accepted when the DB allowlist is empty (bootstrap).
AUTH_DEV_CERT_CNS=senatran-dev-client
